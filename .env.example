# ============================================================
# TAURUS THRIFT — Environment Variables
# Copy this file to .env and fill in your values.
# ============================================================

# ── Database (PostgreSQL) ────────────────────────────────────
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
# macOS Homebrew (no password):  postgresql://your_username@localhost:5432/taurus_thrift?schema=public
# Linux / Docker / with password: postgresql://postgres:password@localhost:5432/taurus_thrift?schema=public
DATABASE_URL="postgresql://postgres:password@localhost:5432/taurus_thrift?schema=public"

# ── NextAuth v5 ──────────────────────────────────────────────
# AUTH_SECRET must be at least 32 random characters.
# Generate one with: openssl rand -base64 32
AUTH_SECRET="your-secret-key-here-minimum-32-characters-long!!"
NEXTAUTH_URL="http://localhost:3000"

# ── Cloudinary (image uploads for products & banners) ────────
# Sign up free at https://cloudinary.com — credentials in Dashboard > API Keys
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"
# Must match CLOUDINARY_CLOUD_NAME (exposed to browser)
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME="your-cloud-name"

# ── App ──────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
