# ============================================================
# TAURUS THRIFT — Environment Variables
# Copy this file to .env and fill in your values.
# ============================================================

# ── Database (PostgreSQL — Supabase) ──────────────────────────
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
# Use your Supabase project's pooled (transaction-mode, port 6543) connection string
# for the app's runtime queries (Project Settings > Database > Connection pooling).
DATABASE_URL="postgresql://postgres:password@localhost:5432/taurus_thrift?schema=public"
# Used only by Prisma Migrate (advisory locks need a session-capable connection —
# the transaction-mode pooler above doesn't support them). Use the same pooler host
# with port 5432 (session mode), or Supabase's direct connection string.
DIRECT_URL="postgresql://postgres:password@localhost:5432/taurus_thrift?schema=public"

# ── NextAuth v5 ──────────────────────────────────────────────
# AUTH_SECRET must be at least 32 random characters.
# Generate one with: openssl rand -base64 32
AUTH_SECRET="your-secret-key-here-minimum-32-characters-long!!"
NEXTAUTH_URL="http://localhost:3000"

# ── Supabase Storage (image uploads for products & banners) ──
# Find these in Project Settings > API
NEXT_PUBLIC_SUPABASE_URL="https://your-project-ref.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# ── App ──────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
